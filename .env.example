# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Modelo Gemini (opcional). Por defecto prueba: flash-lite → 2.5-flash → flash-latest
# GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI API Key — fallback si Gemini falla (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Firebase — credenciales del Service Account
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Hora de envío de notificaciones (formato 24h, zona Europe/Madrid)
# El cron job en Vercel corre a las 7:00 UTC = 9:00 Madrid (verano)
NOTIFICATION_HOUR=9

# Secreto para proteger el endpoint /api/cron (inventa una cadena larga)
CRON_SECRET=
